    "text_mode": false,
    "research_before_questions": true,
    "discuss_auto_all_gray_areas": true,
    "discuss_high_impact_confirm": true,
    "discuss_auto_resolve_low_impact": true,
    "discuss_default_billing_facade_telemetry": "allowlist_safe_dimensions",

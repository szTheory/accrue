# Example secrets file for local CI replay via `act`.
#
# Copy to `.secrets` (git-ignored) and populate with real Stripe test-mode
# credentials before running:
#
#     act workflow_dispatch \
#       -W .github/workflows/ci.yml \
#       -j live-stripe \
#       --secret-file .secrets
#
# DO NOT commit a populated `.secrets` file. `.gitignore` excludes it
# at repo root. Any value beginning with `sk_live_` is a production
# secret and MUST NOT go into this file or any `act` run — live-Stripe
# tests run against test mode only.

# Stripe test-mode secret key. Get from
# https://dashboard.stripe.com/test/apikeys (Secret key, NOT the
# restricted keys).
STRIPE_TEST_SECRET_KEY=sk_test_replace_me

# Optional: pre-seeded price IDs in your Stripe test-mode account that
# the live-Stripe proration fidelity test uses. Skips cleanly if unset.
ACCRUE_LIVE_BASIC_PRICE=price_replace_me_basic
ACCRUE_LIVE_PRO_PRICE=price_replace_me_pro
